<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ SplashScreen API -->
<resources>
    <style name="LaunchTheme" parent="Theme.SplashScreen">
        <!-- Ícono centrado en el splash nativo -->
        <item name="windowSplashScreenBackground">#1A1A1A</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenBrandingImage">@drawable/splash_branding</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">#1A1A1A</item>
    </style>
</resources>
